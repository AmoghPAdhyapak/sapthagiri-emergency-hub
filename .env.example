# =============================================================================
# Sapthagiri NPS University — Emergency Medical Portal
# Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ── API SERVER (required) ────────────────────────────────────────────────────

# Port the Express API server listens on
PORT=8080

# Secret for session cookie signing — use a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# Fast2SMS API key for OTP delivery (https://fast2sms.com → API → Dev API key)
FAST2SMS_API_KEY=your-fast2sms-api-key

# Google Gemini AI key (https://aistudio.google.com/app/apikey)
# Used for the AI Assistant chat panel in both Staff and Patient portals
GEMINI_API_KEY=your-google-gemini-api-key

# ── DATABASE (optional) ──────────────────────────────────────────────────────

# Override where hospital_ecosystem.db is stored.
# Defaults to: artifacts/api-server/hospital_ecosystem.db
# On Railway/Render/VPS: point to a mounted persistent volume.
# DATABASE_STORAGE_PATH=/data/sapthagiri

# PostgreSQL connection (only required if Gemini conversation history DB is used)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── FRONTEND BUILD (set at build time, not runtime) ──────────────────────────

# URL base path for the Vite build — use / for root-hosted deployments
# BASE_PATH=/

# Port for the Vite dev server (different from the API server port above)
# PORT=23183

# ── REPLIT-MANAGED (auto-set by Replit, do not set manually) ─────────────────
# AI_INTEGRATIONS_GEMINI_BASE_URL=  (Replit proxy URL — auto-set)
# AI_INTEGRATIONS_GEMINI_API_KEY=   (Replit proxy key — auto-set)
# REPL_ID=                          (Replit env detection)
