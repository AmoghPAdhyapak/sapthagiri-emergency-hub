# =============================================================================
# Sapthagiri NPS University — Emergency Medical Portal
# Environment Variables Reference
# =============================================================================
# Copy this file to .env for local development.
# NEVER commit .env to git (it is gitignored).
# =============================================================================

# ── VERCEL (set these in Vercel → Project → Settings → Environment Variables) ─

# URL of your deployed API backend (Railway / Render / VPS).
# The Vercel Edge proxy at /api/[...path].ts forwards all /api/* calls here.
# Example: https://sapthagiri-api.up.railway.app
BACKEND_URL=https://your-backend.up.railway.app

# ── API SERVER (set in Railway / Render / VPS) ───────────────────────────────

# Port the Express server listens on.
# Railway/Render set this automatically. For local dev use 8080.
PORT=8080

# Secret for session cookie signing — must be a long random string (≥ 32 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-long-random-secret

# Fast2SMS API key for OTP delivery (https://fast2sms.com → API → Dev API key)
FAST2SMS_API_KEY=your-fast2sms-api-key

# Google Gemini AI key (https://aistudio.google.com/app/apikey)
# Powers the AI Assistant chat panel in both Staff and Patient portals.
GEMINI_API_KEY=your-google-gemini-api-key

# ── DATABASE (API server) ─────────────────────────────────────────────────────

# Override where hospital_ecosystem.db is stored.
# Defaults to: artifacts/api-server/ (next to the compiled bundle)
# On Railway/Render: set to the mounted persistent volume path.
DATABASE_STORAGE_PATH=/data/sapthagiri

# PostgreSQL connection — required ONLY if Gemini conversation history
# persistence is enabled (lib/db). Optional otherwise.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── FRONTEND BUILD (Vercel injects these automatically via vercel.json) ───────
# Do not set these manually in Vercel — they are in vercel.json already.
# BASE_PATH=/
# PORT=3000

# ── LOCAL DEVELOPMENT ONLY ───────────────────────────────────────────────────
# Start the API: PORT=8080 SESSION_SECRET=dev FAST2SMS_API_KEY=x GEMINI_API_KEY=x node --enable-source-maps artifacts/api-server/dist/index.mjs
# Start the UI:  PORT=23183 BASE_PATH=/ pnpm --filter @workspace/dashboard run dev
